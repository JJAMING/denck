{
  "name": "dentistcarepro",
  "private": true,
  "version": "0.0.0",
  "author": {
    "name": "JJAMING",
    "email": "skyja@example.com"
  },
  "description": "Dentist Form Application",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "wait-on http://localhost:5173 && electron .",
    "electron:dev": "concurrently \"npm run dev\" \"cross-env NODE_ENV=development npm run electron\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.0",
    "konva": "^10.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-konva": "^19.2.3",
    "use-image": "^1.1.4",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.dentistcare.app",
    "productName": "DentistCare",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "removePackageKeywords": true,
    "removePackageScripts": true,
    "files": [
      "dist/**/*",
      "main.js",
      "package.json",
      "public/**/*"
    ],
    "asar": true
  }
}
